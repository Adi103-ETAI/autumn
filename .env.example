# ----------------------------------------------------------------------------
# Autumn — environment variables
# Copy this file to `.env` and fill in the values for your environment.
#   cp .env.example .env
# ----------------------------------------------------------------------------

# Prisma datasource URL.
# SQLite is the default (file-based, no server required).
# The path is relative to the project root unless absolute.
DATABASE_URL="file:./db/custom.db"

# Alternative: use a different SQLite path
# DATABASE_URL="file:/absolute/path/to/autumn.db"

# ----------------------------------------------------------------------------
# Next.js runtime
# ----------------------------------------------------------------------------
# Set to "production" for production builds, "development" otherwise.
# Next.js sets this automatically; no need to define it manually.
# NODE_ENV="development"
